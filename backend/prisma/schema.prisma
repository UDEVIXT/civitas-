generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  Gobierno
  Comite
}

enum Rol {
  Administrador
  Guardia
  Residente
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EstatusAcceso {
  Activo
  Inactivo
}

enum EstadoUsuario {
  ACTIVO
  SUSPENDIDO
}

enum TipoReporte {
  QUEJA
  SUGERENCIA
  INCIDENCIA
}

enum PrioridadReporte {
  BAJA
  MEDIA
  ALTA
}

enum EstadoIncidencia {
  PENDIENTE
  EN_PROCESO
  RESUELTA
  CANCELADA
}

model Persona {
  id_persona       String   @id @default(uuid())
  nombre           String
  genero           String
  fecha_nacimiento DateTime
  telefono         String?
  url_imagen       String?
  usuario          Usuario?
}

model Vivienda {
  id_vivienda     String      @id @default(uuid())
  numero_vivienda String      @unique
  residentes      Residente[]
  servicios       Servicio[]
}

model Usuario {
  id_usuario                String          @id @default(uuid())
  nombre_usuario            String          @unique
  correo                    String          @unique
  rol                       Rol
  id_persona                String          @unique
  password                  String
  estado                    EstadoUsuario  @default(ACTIVO)
  resetPasswordToken        String?
  resetPasswordExpires      DateTime?
  correo_verificado         Boolean        @default(false)
  token_verificacion        String?        @unique
  accesos                   Acceso[]
  administradores           Administrador?
  guardias                  Guardia?
  residentes                Residente[]
  persona                   Persona        @relation(fields: [id_persona], references: [id_persona])
  sesiones                  Sesion[]
  reportes                  Reporte[]
  solicitudes_admin_guardia Solicitud_administrador_guardia[]
  desactivaciones_qr        BitacoraDesactivacionQr[]
  bitacora_qr_visitantes    BitacoraQrVisitante[]
  accesos_preautorizados    AccesoPreautorizado[]
}

model Residente {
  id_residente String @id @default(uuid())
  id_usuario   String
  id_vivienda  String

  usuario     Usuario      @relation(fields: [id_usuario], references: [id_usuario])
  vivienda    Vivienda     @relation(fields: [id_vivienda], references: [id_vivienda])
  visitantes  Visitante[]
  servicios   Servicio[]
}

model Visitante {
  id_visitante String    @id @default(uuid())
  nombre       String
  es_frecuente Boolean   @default(false)
  tipo_visitante String?
  telefono     String?
  url_imagen   String?
  tipo_vehiculo String?
  motivo       String?
  notas_adicionales String? @db.Text
  id_residente String
  id_servicio  String?
  accesos      Acceso[]
  residente    Residente @relation(fields: [id_residente], references: [id_residente])
  servicio     Servicio? @relation(fields: [id_servicio], references: [id_servicio])
}

model Acceso {
  id_acceso        String        @id @default(uuid())
  id_usuario       String
  id_visitante     String?
  codigo_qr        String?       @unique
  fecha_creacion   DateTime      @default(now())
  fecha_visita_programada DateTime?
  fecha_salida_programada DateTime?
  fecha_expiracion DateTime
  estatus          EstatusAcceso @default(Activo)
  comentario_admin String?
  usuario          Usuario       @relation(fields: [id_usuario], references: [id_usuario])
  visitante        Visitante?    @relation(fields: [id_visitante], references: [id_visitante], onDelete: Cascade)
  bitacora         Bitacora[]
  bitacora_desactivaciones BitacoraDesactivacionQr[]
  bitacora_qr_visitantes    BitacoraQrVisitante[]
  acceso_preautorizado  AccesoPreautorizado[]
}

model Bitacora {
  id_bitacora        String    @id @default(uuid())
  id_acceso          String
  id_guardia         String?
  id_guardia_salida  String?
  fecha_hora_entrada DateTime  @default(now())
  fecha_hora_salida  DateTime?
  comentario         String?
  comentario_salida  String?
  estado             Boolean   @default(true)
  acceso             Acceso    @relation(fields: [id_acceso], references: [id_acceso], onDelete: Cascade)
  guardia            Guardia?  @relation("GuardiaEntrada", fields: [id_guardia], references: [id_guardia])
  guardia_salida Guardia? @relation("GuardiaSalida", fields: [id_guardia_salida], references: [id_guardia])
}

model Servicio {
  id_servicio      String                   @id @default(uuid())
  nombre_servicio  String
  cargo            String?
  nombre_empresa   String?
  tipo_carro       String?
  placas           String?                  @unique
  rfc              String?
  activo           Boolean                  @default(true)
  bloqueo_global   Boolean                  @default(false)
  id_tipo_servicio String?
  id_residente     String
  id_vivienda      String
  fecha_registro   DateTime                 @default(now())
  horarios         HorarioAccesoServicios[]
  tipo_servicio    TipoServicio?            @relation(fields: [id_tipo_servicio], references: [id_tipo_servicio])
  visitantes       Visitante[]
  residente        Residente @relation(fields: [id_residente], references: [id_residente])
  vivienda         Vivienda @relation(fields: [id_vivienda], references: [id_vivienda])

  @@index([rfc])
}

model HorarioAccesoServicios {
  id_horario  String    @id @default(uuid())
  hora_inicio DateTime  @db.Time(6)
  hora_fin    DateTime  @db.Time(6)
  activo      Boolean   @default(true)
  dia_semana  DiaSemana
  id_servicio String
  servicio    Servicio  @relation(fields: [id_servicio], references: [id_servicio])

  @@index([dia_semana, activo])
}

model Guardia {
  id_guardia String     @id @default(uuid())
  id_usuario String     @unique
  nombre     String     @db.VarChar(128)
  numero_empleado String? @unique
  turno      String?
  bitacoras         Bitacora[] @relation("GuardiaEntrada")
  bitacoras_salida  Bitacora[] @relation("GuardiaSalida")
  usuario    Usuario    @relation(fields: [id_usuario], references: [id_usuario])
}

model TipoServicio {
  id_tipo_servicio String     @id @default(uuid())
  nombre           String     @unique
  descripcion      String?
  categoria        String
  servicios        Servicio[]
}

model Administrador {
  id_administrador String  @id @default(uuid())
  id_usuario       String  @unique
  nombre           String  @db.VarChar(128)
  apellidos        String?  @db.VarChar(128)
  numero_empleado  String? @unique
  cargo            Cargo?
  usuario          Usuario @relation(fields: [id_usuario], references: [id_usuario])
}

model EvidenciaReporte {
  id_evidencia   String   @id @default(uuid())
  id_reporte     String
  reporte        Reporte  @relation(fields: [id_reporte], references: [id_reporte])
  url_archivo    String   @db.Text
  nombre_archivo String   @db.VarChar(256)
  createdAt      DateTime @default(now()) @db.Timestamp()
}

model Reporte {
  id_reporte         String           @id @default(uuid())
  id_usuario         String
  usuario            Usuario          @relation(fields: [id_usuario], references: [id_usuario])
  motivo             String           @db.VarChar(100)
  descripcion        String           @db.Text
  tipo               TipoReporte
  latitud            Decimal
  longitud           Decimal
  estado             EstadoIncidencia
  prioridad          PrioridadReporte
  es_anonimo         Boolean
  token_seguimiento  String? @unique
  resultado_esperado String?          @db.Text
  resultado_solucion String?          @db.Text
  createdAt          DateTime         @default(now())
  evidencias EvidenciaReporte[]
}

model Sesion {
  id_sesion      String   @id @default(uuid())
  id_usuario     String
  refresh_token  String
  activo         Boolean  @default(true)
  ip             String?
  dispositivo    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user_agent     String?
  usuario Usuario @relation( fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  @@map("sesiones")
}

enum Estatus_Solicitud {
  Pendiente
  Aceptada
  Rechazada
}

model Solicitud_administrador_guardia {
  id_solicitud      String            @id @default(uuid())
  id_usuario        String          @unique
  rol_solicitado    Rol
  nombre           String
  genero           String
  fecha_nacimiento DateTime
  telefono         String?
  correo             String         @unique
  numero_empleado    String?        @unique
  credencial_frente_key  String?
  credencial_reverso_key String?
  estatus_solicitud Estatus_Solicitud @default(Pendiente)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  usuario           Usuario           @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
}

model BitacoraDesactivacionQr {
  id_desactivacion String   @id @default(uuid())
  id_acceso        String
  id_usuario       String
  motivo           String?  @db.Text
  fecha_hora       DateTime @default(now())

  acceso           Acceso   @relation(fields: [id_acceso], references: [id_acceso], onDelete: Cascade)
  usuario          Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  @@index([id_acceso])
}

model BitacoraQrVisitante {
  id_bitacora_qr String   @id @default(uuid())
  id_acceso      String
  id_usuario     String
  accion         String   @db.VarChar(32)
  motivo         String?  @db.Text
  fecha_hora     DateTime @default(now())

  acceso         Acceso   @relation(fields: [id_acceso], references: [id_acceso], onDelete: Cascade)
  usuario        Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@index([id_acceso])
  @@index([id_usuario])
  @@index([accion])
}

enum Tipo_Visita {
  Visitante
  Proveedor
  Empleado
}

enum Estado_QR {
  Activo
  Expirado
  Desactivado
}

model AccesoPreautorizado {
  id_acceso_preautorizado String      @id @default(uuid())
  nombre                  String
  informacion_general     String?     @db.Text
  propiedad               String
  nombre_residente        String
  fecha_llegada           DateTime?
  fecha_salida            DateTime? 
  fecha_expiracion        DateTime
  tipo                    Tipo_Visita
  tiene_nota              Boolean     @default(false)
  
  id_usuario              String          
  id_acceso               String?         

  usuario                 Usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  acceso                  Acceso?     @relation(fields: [id_acceso], references: [id_acceso], onDelete: Cascade)
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}