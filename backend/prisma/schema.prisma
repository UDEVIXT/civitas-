generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum EstatusAcceso {
  Activo
  Inactivo
}

enum Rol {
  Administrador
  Guardia
  Residente
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum Cargo {
  Gobierno
  Comite
}

model Persona {
  id_persona       String   @id @default(uuid())
  nombre           String
  genero           String
  fecha_nacimiento DateTime
  telefono         String?
  url_imagen       String?

  usuario Usuario?
}

model Vivienda {
  id_vivienda     String @id @default(uuid())
  numero_vivienda String @unique

  residentes Residente[]
}

model Usuario {
  id_usuario String @id @default(uuid())
  nombre_usuario String @unique
  correo         String @unique
  password       String
  rol            Rol
  id_persona     String @unique

  persona    Persona     @relation(fields: [id_persona], references: [id_persona])
  accesos    Acceso[]
  residentes Residente[]
  guardias   Guardia?
  administradores Administrador[]
}

model Residente {
  id_residente String @id @default(uuid())
  id_usuario   String
  id_vivienda  String

  usuario    Usuario     @relation(fields: [id_usuario], references: [id_usuario])
  vivienda   Vivienda    @relation(fields: [id_vivienda], references: [id_vivienda])
  visitantes Visitante[]
}

model Visitante {
  id_visitante String  @id @default(uuid())
  nombre       String
  es_frecuente Boolean @default(false)
  telefono     String?
  url_imagen   String?
  motivo       String?
  id_residente String
  id_servicio  String?

  residente Residente @relation(fields: [id_residente], references: [id_residente])
  servicio  Servicio? @relation(fields: [id_servicio], references: [id_servicio])
  accesos   Acceso[]
}

model Acceso {
  id_acceso        String        @id @default(uuid())
  id_usuario       String
  id_visitante     String
  codigo_qr        String        @unique
  fecha_creacion   DateTime      @default(now())
  fecha_expiracion DateTime
  estatus          EstatusAcceso @default(Activo)
  comentario_admin String?

  usuario   Usuario   @relation(fields: [id_usuario], references: [id_usuario])
  visitante Visitante @relation(fields: [id_visitante], references: [id_visitante])
  bitacora  Bitacora?
}

model Bitacora {
  id_bitacora        String    @id @default(uuid())
  id_acceso          String    @unique
  id_guardia         String
  fecha_hora_entrada DateTime  @default(now())
  fecha_hora_salida  DateTime?
  comentario         String?
  comentario_salida  String?

  acceso       Acceso  @relation(fields: [id_acceso], references: [id_acceso])
  guardia      Guardia  @relation(fields: [id_guardia], references: [id_guardia])
}

model Servicio {
  id_servicio     String  @id @default(uuid())
  nombre_servicio String
  cargo           String?
  nombre_empresa  String?
  tipo_carro      String?
  placas          String? @unique
  rfc             String? @unique
  activo          Boolean @default(true)

  id_tipo_servicio String?
  tipo_servicio    TipoServicio? @relation(fields: [id_tipo_servicio], references: [id_tipo_servicio])
  visitantes Visitante[]
  horarios   HorarioAccesoServicios[]
}

model HorarioAccesoServicios {
  id_horario  String    @id @default(uuid())
  dia_semana  DiaSemana
  hora_inicio DateTime  @db.Time
  hora_fin    DateTime  @db.Time
  id_servicio String
  activo      Boolean   @default(true)

  servicio Servicio @relation(fields: [id_servicio], references: [id_servicio])

  @@index([dia_semana, activo])
}

enum TipoReporte {
  QUEJA
  SUGERENCIA
  INCIDENCIA
}

enum EstadoReporte {
  PENDIENTE
  EN_PROCESO
  RESUELTO
}

enum PrioridadReporte {
  BAJA
  MEDIA
  ALTA
}
  
model Reporte {
  id_reporte         String                @id @default(uuid()) @db.Uuid
  id_usuario         String                @db.Uuid
  motivo             String                @db.VarChar(100)
  descripcion        String                @db.Text
  tipo               TipoReporte
  latitud            Decimal
  longitud           Decimal
  estado             EstadoReporte
  prioridad          PrioridadReporte
  es_anonimo         Boolean
  resultado_esperado String?               @db.Text
  resultado_solucion String?               @db.Text
  evidencias         EvidenciaIncidencia[]
}

model EvidenciaIncidencia {
  id_evidencia   String   @id @default(uuid()) @db.Uuid
  id_reporte     String   @db.Uuid
  reporte        Reporte  @relation(fields: [id_reporte], references: [id_reporte])
  url_archivo    String   @db.Text
  nombre_archivo String   @db.VarChar(256)
  createdAt      DateTime @default(now()) @db.Timestamp()
}
model Guardia {
  id_guardia  String     @id @default(uuid())
  id_usuario  String     @unique
  nombre      String     @db.VarChar(128)
  turno       String

  usuario     Usuario    @relation(fields: [id_usuario], references: [id_usuario])
  bitacoras   Bitacora[]
}

model TipoServicio {
  id_tipo_servicio String @id @default(uuid())
  categoria        String  // "Limpieza", "Repartidor", "Mantenimiento", "Proveedor"
  nombre           String @unique
  descripcion      String?

  servicios Servicio[]
}

model Administrador {
  id_administrador String    @id @default(uuid())
  id_usuario       String    @unique
  nombre           String    @db.VarChar(128)
  apellidos        String    @db.VarChar(128)
  cargo            Cargo
  usuario          Usuario @relation(fields: [id_usuario], references: [id_usuario])
}
