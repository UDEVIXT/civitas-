generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  Gobierno
  Comite
}

enum Rol {
  Administrador
  Guardia
  Residente
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EstatusAcceso {
  Activo
  Inactivo
}

enum EstadoUsuario {
  ACTIVO
  SUSPENDIDO
}

enum TipoReporte {
  QUEJA
  SUGERENCIA
  INCIDENCIA
}

enum PrioridadReporte {
  BAJA
  MEDIA
  ALTA
}

enum EstadoIncidencia {
  PENDIENTE
  EN_PROCESO
  RESUELTA
  CANCELADA
}

model Persona {
  id_persona       String   @id @default(uuid())
  nombre           String
  genero           String
  fecha_nacimiento DateTime
  telefono         String?
  url_imagen       String?
  usuario          Usuario?
}

model Vivienda {
  id_vivienda     String      @id @default(uuid())
  numero_vivienda String      @unique
  residentes      Residente[]
  servicios       Servicio[]
}

model Usuario {
  id_usuario         String         @id @default(uuid())
  nombre_usuario     String         @unique
  correo             String         @unique
  rol                Rol
  id_persona         String         @unique
  password           String
  estado             EstadoUsuario  @default(ACTIVO)
  // --- Campos nuevos para recuperación de contraseña ---
  // Almacena el código (ej. "123456") o un token generado
  resetPasswordToken   String?

  // Almacena la fecha y hora exacta en que el código dejará de ser válido
  resetPasswordExpires DateTime?
  correo_verificado  Boolean        @default(false)
  token_verificacion String?        @unique
  accesos            Acceso[]
  administradores    Administrador?
  guardias           Guardia?
  residentes         Residente[]
  persona            Persona        @relation(fields: [id_persona], references: [id_persona])
  sesiones Sesion[]
  reportes             Reporte[]
}

model Residente {
  id_residente String @id @default(uuid())
  id_usuario   String
  id_vivienda  String

  usuario     Usuario      @relation(fields: [id_usuario], references: [id_usuario])
  vivienda    Vivienda     @relation(fields: [id_vivienda], references: [id_vivienda])
  visitantes  Visitante[]
  servicios   Servicio[]
}

model Visitante {
  id_visitante String    @id @default(uuid())
  nombre       String
  es_frecuente Boolean   @default(false)
  telefono     String?
  url_imagen   String?
  tipo_vehiculo String?
  motivo       String?
  id_residente String
  id_servicio  String?
  accesos      Acceso[]
  residente    Residente @relation(fields: [id_residente], references: [id_residente])
  servicio     Servicio? @relation(fields: [id_servicio], references: [id_servicio])
}

model Acceso {
  id_acceso        String        @id @default(uuid())
  id_usuario       String
  id_visitante     String?
  codigo_qr        String?       @unique
  fecha_creacion   DateTime      @default(now())
  fecha_expiracion DateTime
  estatus          EstatusAcceso @default(Activo)
  comentario_admin String?
  usuario          Usuario       @relation(fields: [id_usuario], references: [id_usuario])
  visitante        Visitante?    @relation(fields: [id_visitante], references: [id_visitante], onDelete: Cascade)
  bitacora         Bitacora[]
}

model Bitacora {
  id_bitacora        String    @id @default(uuid())
  id_acceso          String
  id_guardia         String?
  id_guardia_salida  String?
  fecha_hora_entrada DateTime  @default(now())
  fecha_hora_salida  DateTime?
  comentario         String?
  comentario_salida  String?
  acceso             Acceso    @relation(fields: [id_acceso], references: [id_acceso], onDelete: Cascade)
  guardia            Guardia?  @relation("GuardiaEntrada", fields: [id_guardia], references: [id_guardia])
  guardia_salida Guardia? @relation("GuardiaSalida", fields: [id_guardia_salida], references: [id_guardia])
}

model Servicio {
  id_servicio      String                   @id @default(uuid())
  nombre_servicio  String
  cargo            String?
  nombre_empresa   String?
  tipo_carro       String?
  placas           String?                  @unique
  rfc              String?                  @unique
  activo           Boolean                  @default(true)
  id_tipo_servicio String?
  id_residente     String
  id_vivienda      String
  fecha_registro   DateTime                 @default(now())
  horarios         HorarioAccesoServicios[]
  tipo_servicio    TipoServicio?            @relation(fields: [id_tipo_servicio], references: [id_tipo_servicio])
  visitantes       Visitante[]
  residente        Residente @relation(fields: [id_residente], references: [id_residente])
  vivienda         Vivienda @relation(fields: [id_vivienda], references: [id_vivienda])
}

model HorarioAccesoServicios {
  id_horario  String    @id @default(uuid())
  hora_inicio DateTime  @db.Time(6)
  hora_fin    DateTime  @db.Time(6)
  activo      Boolean   @default(true)
  dia_semana  DiaSemana
  id_servicio String
  servicio    Servicio  @relation(fields: [id_servicio], references: [id_servicio])

  @@index([dia_semana, activo])
}

model Guardia {
  id_guardia String     @id @default(uuid())
  id_usuario String     @unique
  nombre     String     @db.VarChar(128)
  turno      String
  bitacoras         Bitacora[] @relation("GuardiaEntrada")
  bitacoras_salida  Bitacora[] @relation("GuardiaSalida")
  usuario    Usuario    @relation(fields: [id_usuario], references: [id_usuario])
}

model TipoServicio {
  id_tipo_servicio String     @id @default(uuid())
  nombre           String     @unique
  descripcion      String?
  categoria        String
  servicios        Servicio[]
}

model Administrador {
  id_administrador String  @id @default(uuid())
  id_usuario       String  @unique
  nombre           String  @db.VarChar(128)
  apellidos        String  @db.VarChar(128)
  cargo            Cargo
  usuario          Usuario @relation(fields: [id_usuario], references: [id_usuario])
}

model EvidenciaReporte {
  id_evidencia   String   @id @default(uuid())
  id_reporte     String
  reporte        Reporte  @relation(fields: [id_reporte], references: [id_reporte])
  url_archivo    String   @db.Text
  nombre_archivo String   @db.VarChar(256)
  createdAt      DateTime @default(now()) @db.Timestamp()
}

model Reporte {
  id_reporte         String           @id @default(uuid())
  id_usuario         String
  usuario            Usuario          @relation(fields: [id_usuario], references: [id_usuario])
  motivo             String           @db.VarChar(100)
  descripcion        String           @db.Text
  tipo               TipoReporte
  latitud            Decimal
  longitud           Decimal
  estado             EstadoIncidencia
  prioridad          PrioridadReporte
  es_anonimo         Boolean
  token_seguimiento  String? @unique
  resultado_esperado String?          @db.Text
  resultado_solucion String?          @db.Text
  createdAt          DateTime         @default(now())
  evidencias EvidenciaReporte[]
}

model Sesion {
  id_sesion      String   @id @default(uuid())
  id_usuario     String
  refresh_token  String
  activo         Boolean  @default(true)
  ip             String?
  dispositivo    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user_agent     String?
  usuario Usuario @relation( fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  @@map("sesiones")
}
